{
  "directoryListing": ["/dumps", "/dumps/**"],
  "headers": [
    {
      "source": "**/*.@(fgb|parquet|pmtiles)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Headers", "value": "range" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ]
}
